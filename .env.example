# ============================================
# Grabarr — local environment overrides
# ============================================
# Copy to .env (gitignored). Most values default sensibly; the only
# variables you'll typically set locally are HOST/PORT.

# HTTP server (consumed by start.sh)
HOST=0.0.0.0
PORT=8080

# Bypass mode: external (FlareSolverr) | internal (SeleniumBase) | auto | off
GRABARR_BYPASS_MODE=internal

# IA contact email — recommended by archive.org's API policy.
GRABARR_IA_CONTACT_EMAIL=

# Optional: pin the AA member donator key to skip slow-tier search.
GRABARR_SOURCES__ANNA_ARCHIVE__MEMBER_KEY=

# ============================================
# CI release variables (set in GitLab → Settings → CI/CD → Variables,
# NOT in this .env). Listed here for documentation only.
# ============================================
# DOCKER_HUB_USER=sharkhunterr
# DOCKER_HUB_TOKEN=<token-from-hub.docker.com/settings/security>
# GITHUB_TOKEN=<github-PAT-with-repo-scope>
# GITHUB_REPO=sharkhunterr/grabarr
